# =========================
# Google Gemini / LangChain
# =========================
GOOGLE_API_KEY=isi_api_key_google_ai_studio
GOOGLE_MODEL=gemini-2.5-flash

# =========================
# LangSmith Observability
# =========================
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=isi_api_key_langsmith
LANGSMITH_PROJECT=uas-nlp-studymate

# Optional: bila API key belum tersedia, aktifkan mode demo.
# Mode demo hanya untuk melihat antarmuka, bukan untuk demo final UAS.
DEMO_MODE=false

# Quality threshold untuk routing LangGraph
QUALITY_THRESHOLD=80
MAX_REVISIONS=1
